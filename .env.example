## Firebase config for Expo — add these to app.json > expo > extra
## or use expo-constants with an app.config.ts dynamic config.
##
## Required:
# firebaseApiKey=
# firebaseAuthDomain=
# firebaseProjectId=
# firebaseAppId=
##
## Optional:
# firebaseStorageBucket=
# firebaseMessagingSenderId=
# firebaseMeasurementId=
##
## See app.json "extra" field for where to place these values.
## Do NOT commit real values — keep secrets out of version control.
